/// Root schema for a SearchBench round manifest.
///
/// The only author-facing entry point is `round`, which either defines a round
/// from scratch or continues from an explicit completed bundle path.
@go.Package { name = "github.com/becker63/searchbench-go/internal/adapters/config/pkl/generated" }
module searchbench.config.SearchBenchRound

import "package://pkg.pkl-lang.org/pkl-go/pkl.golang@0.13.2#/go.pkl"

/// Stable game identity for this round (used in bundle layout and reporting).
game: Game = new {}

/// Human-readable round name; may influence default bundle IDs and reports.
name: String = ""

/// Declares interface contracts referenced by policy artifacts.
interfaces: Interfaces = new {}

/// Continuation-backed round surface used by concise game-level manifests.
round: RoundManifest?

/// Upstream dataset family; currently only LCA-style bug localization is supported.
typealias DatasetKind = "lca"

/// Execution backend for a policy system.
typealias Backend = "iterative_context" | "jcodemunch" | "fake"

/// LLM provider id for agent models.
typealias Provider = "openai" | "openrouter" | "cerebras" | "fake"

/// IC workspace seed provider for optimizable IC-backed systems.
typealias WorkspaceSeedProvider = "local_path" | "buck_descriptor" | "git" | "archive"

/// Formats written for the round report.
typealias ReportFormat = "json" | "text"

/// Evidence kinds the optimizer may pull from the parent bundle.
typealias NextChallengerEvidenceKind =
  "report_summary" | "round_evidence" | "objective_result" | "challenger_policy"

/// Labels for evidence the optimizer prompt must never include.
typealias OptimizerDeniedEvidenceKind = "gold_labels" | "oracle_files" | "raw_dataset_answers"

/// Logical game this round belongs to.
class Game {
  id: String = "code-localization"
  kind: String = "code_localization"
}

/// Selects a dataset slice from an upstream bug-localization benchmark.
class Dataset {
  kind: DatasetKind = "lca"
  name: String = "JetBrains-Research/lca-bug-localization"
  config: String
  split: String
  maxItems: Int(this > 0)?
}

/// Declares interface identifiers that policies and artifacts must satisfy.
class Interfaces {
  iterativeContextSelectionPolicyV1: Interface = new {
    id = "iterative_context.selection_policy.v1"
  }
}

/// Named capability contract.
class Interface {
  id: String
}

/// One executable policy system.
class System {
  id: String
  name: String = id
  backend: Backend
  promptBundle: PromptBundle = new {}
  runtime: Runtime = new {}
}

/// Locates the prompt bundle material for a system.
class PromptBundle {
  name: String = "default"
  version: String? = "dev"
}

/// Hard limits while executing one system on one match.
class Runtime {
  maxSteps: Int(this > 0) = 16
  timeoutSeconds: Int(this > 0) = 300
  /// Optional IC workspace seed provider wiring (logical; repo Buck targets stay internal).
  workspaceSeed: WorkspaceSeedConfig?
}

/// Declares how an IC optimizable backend seed is obtained for candidate workspaces.
class WorkspaceSeedConfig {
  provider: WorkspaceSeedProvider = "local_path"
  /// Required when provider is local_path (repo-relative or absolute path).
  localPath: String?
  /// Required when provider is buck_descriptor (repo-internal Buck label).
  buckDescriptorTarget: String?
}

/// A versioned policy artifact implementing a declared interface.
class PolicyArtifact {
  id: String
  kind: "policy" = "policy"
  path: String
  implements: Interface
}

/// Author-facing round surface: either define a round from scratch or continue
/// from an explicit completed bundle path.
class RoundManifest {
  id: String
  continues: String?
  incumbent: RoundPolicy?
  challenger: RoundChallenger
  matches: Dataset?
  evaluator: Evaluator?
  scoring: Scoring?
  report: Report = new {}
}

/// One executable round-side policy declaration.
class RoundPolicy {
  system: System
  selectionPolicy: PolicyArtifact?
}

/// Challenger patch for the concise round surface.
class RoundChallenger {
  system: System?
  selectionPolicy: PolicyArtifact?
  generate: GeneratedChallenger?
}

/// Request to materialize the challenger through the optimizer seam before the
/// round is evaluated.
class GeneratedChallenger {
  optimizer: Optimizer
  artifactName: String = "generated_challenger_policy.py"
  include: Listing<NextChallengerEvidenceKind> = new {
    "report_summary"
    "round_evidence"
    "objective_result"
    "challenger_policy"
  }
  deny: Listing<OptimizerDeniedEvidenceKind> = new {
    "gold_labels"
    "oracle_files"
    "raw_dataset_answers"
  }
}

/// Allow/deny tool policy for an agent manifest surface.
class AgentToolPolicy {
  allow: Listing<String> = new {}
  deny: Listing<String> = new {}
}

/// LLM call routing for an agent model.
class Model {
  provider: Provider
  name: String
  routing: String?
  maxOutputTokens: Int(this > 0)? = 2000
}

/// Shared safety bounds for agent loops.
class AgentBounds {
  maxModelTurns: Int(this > 0) = 8
  maxToolCalls: Int(this >= 0) = 24
  timeoutSeconds: Int(this > 0) = 300
}

/// Configuration for the SearchBench evaluator agent.
class Evaluator {
  model: Model
  bounds: AgentBounds = new {}
  tools: AgentToolPolicy = new {}
  systemPrompt: String?
  retry: RetryPolicy = new {}
}

/// Configuration for the optimizer agent used to materialize a challenger.
class Optimizer {
  model: Model
  bounds: AgentBounds = new {}
  tools: AgentToolPolicy = new {}
  systemPrompt: String?
}

/// How the harness retries failed evaluator attempts.
class RetryPolicy {
  maxAttempts: Int(this > 0) = 2
  retryOnModelError: Boolean = true
  retryOnToolFailure: Boolean = false
  retryOnFinalizationFailure: Boolean = true
  retryOnInvalidPrediction: Boolean = true
}

/// Locates the scoring objective module relative to the manifest.
class Scoring {
  objective: String
}

/// Human- and machine-readable report outputs for the round bundle.
class Report {
  formats: Listing<ReportFormat> = new {
    "json"
    "text"
  }
}
