import "./code-localization.pkl" as schema

function defineFromScratch(roundId: String): schema.RoundManifest =
  new schema.RoundManifest {
    id = roundId
  }

function continueFrom(bundlePath: String): schema.RoundManifest =
  new schema.RoundManifest {
    continues = bundlePath
  }

function jcodemunch(): schema.RoundPolicy =
  new schema.RoundPolicy {
    system {
      id = "jcodemunch"
      name = "jCodeMunch"
      backend = "jcodemunch"
    }
  }

function iterativeContext(policyPath: String): schema.RoundChallenger =
  new schema.RoundChallenger {
    system {
      id = "iterative-context"
      name = "Iterative Context"
      backend = "iterative_context"
    }

    selectionPolicy {
      id = "challenger-policy"
      kind = "policy"
      path = policyPath
      implements = new schema.Interface {
        id = "iterative_context.selection_policy.v1"
      }
    }
  }

function iterativeContextPolicy(policyPath: String): schema.RoundPolicy =
  new schema.RoundPolicy {
    system {
      id = "iterative-context"
      name = "Iterative Context"
      backend = "iterative_context"
    }

    selectionPolicy {
      id = "challenger-policy"
      kind = "policy"
      path = policyPath
      implements = new schema.Interface {
        id = "iterative_context.selection_policy.v1"
      }
    }
  }

function lca(datasetConfig: String, datasetSplit: String, datasetMaxItems: Int): schema.Dataset =
  new schema.Dataset {
    kind = "lca"
    name = "JetBrains-Research/lca-bug-localization"
    config = datasetConfig
    split = datasetSplit
    maxItems = datasetMaxItems
  }

function objective(objectivePath: String): schema.Scoring =
  new schema.Scoring {
    objective = objectivePath
  }

/// fakeRoundPolicy declares a round-side policy whose system uses the in-process
/// fake backend (no MCP servers).
function fakeRoundPolicy(policyId: String, displayName: String): schema.RoundPolicy =
  new schema.RoundPolicy {
    system {
      id = policyId
      name = displayName
      backend = "fake"
    }
  }

function fakeEvaluator(): schema.Evaluator =
  new schema.Evaluator {
    model {
      provider = "fake"
      name = "fake-evaluator"
      maxOutputTokens = 2000
    }

    bounds {
      maxModelTurns = 8
      maxToolCalls = 24
      timeoutSeconds = 300
    }

    tools {
      allow {
        "resolve"
        "expand"
        "resolve_and_expand"
      }

      deny {
        "shell"
        "go_test"
        "write_file"
        "network"
      }
    }

    systemPrompt = """
    Use structural code evidence before guessing.
    Prefer the smallest plausible file set.
    Do not invent files that were not returned by tools.
    """
  }

function fakeOptimizer(): schema.Optimizer =
  new schema.Optimizer {
    model {
      provider = "fake"
      name = "fake-optimizer"
      maxOutputTokens = 4000
    }

    bounds {
      maxModelTurns = 8
      maxToolCalls = 16
      timeoutSeconds = 300
    }

    tools {
      allow {
        "read_parent_bundle"
        "read_score_evidence"
        "read_objective_result"
        "read_report_summary"
        "read_artifact"
        "write_artifact_proposal"
      }

      deny {
        "run_evaluator"
        "shell"
        "go_test"
        "write_manifest"
        "network"
      }
    }

    systemPrompt = """
    Improve the Iterative Context selection policy using only the provided parent-run evidence.

    Prefer small, inspectable changes.
    Preserve the declared policy interface.
    Do not overfit to hidden labels or oracle files.
    Emit exactly one replacement policy proposal.
    """
  }
