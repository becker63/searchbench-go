amends "../../schema/SearchBenchExperiment.pkl"

name = "local-ic-vs-jcodemunch-round-001"
mode = "evaluation"

interfaces {
  iterativeContextSelectionPolicyV1 {
    id = "iterative_context.selection_policy.v1"
  }
}

dataset {
  kind = "lca"
  name = "JetBrains-Research/lca-bug-localization"
  config = "py"
  split = "dev"
  maxItems = 5
}

systems {
  baseline {
    id = "jcodemunch"
    name = "jCodeMunch"
    backend = "jcodemunch"
  }

  iterativeContext {
    id = "iterative-context"
    name = "Iterative Context"
    backend = "iterative_context"
  }
}

artifacts {
  candidatePolicyRound001 {
    id = "candidate-policy-round-001"
    kind = "policy"
    path = "policies/candidate_policy.py"
    implements = interfaces.iterativeContextSelectionPolicyV1
  }
}

agents {
  evaluator {
    model {
      provider = "fake"
      name = "fake-evaluator"
      maxOutputTokens = 2000
    }

    bounds {
      maxModelTurns = 8
      maxToolCalls = 24
      timeoutSeconds = 300
    }

    tools {
      allow {
        "resolve"
        "expand"
        "resolve_and_expand"
      }

      deny {
        "shell"
        "go_test"
        "write_file"
        "network"
      }
    }

    systemPrompt = """
    Use structural code evidence before guessing.
    Prefer the smallest plausible file set.
    Do not invent files that were not returned by tools.
    """
  }
}

evaluation {
  agent = agents.evaluator

  baseline {
    system = systems.baseline
  }

  candidate {
    system = systems.iterativeContext

    uses {
      selectionPolicy = artifacts.candidatePolicyRound001
    }
  }

  scoring {
    objective = "scoring/localization-objective.pkl"
  }
}
