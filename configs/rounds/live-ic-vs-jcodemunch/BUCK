load("//build_defs:searchbench_round.bzl", "searchbench_round")

# Repo-owned live round — Buck is the supported run/eval interface (#75, #77, #91).
# Secrets: repo-root `.env` (e.g. CEREBRAS_API_KEY). Non-secrets live here.

_ROUND = "live-ic-vs-jcodemunch"
_ROUND_ID = "live-ic-vs-jcodemunch-001"
_ROUND_DIR = "configs/rounds/live-ic-vs-jcodemunch"
_GAME = "code-localization"

_MANIFEST = _ROUND_DIR + "/round.pkl"
_MANIFEST_DIR = _ROUND_DIR
_ARTIFACT_ROOT = _ROUND_DIR + "/artifacts"
_BUNDLE_PATH = _ARTIFACT_ROOT + "/games/" + _GAME + "/rounds/" + _ROUND_ID

_DATASET_CONFIG = "py"
_DATASET_SPLIT = "dev"
_DATASET_MAX_ITEMS = 1
_DATASET_SKIP = 50

_EVALUATE_ATTEMPTS = 3
_STABILITY_ATTEMPTS = 5

searchbench_round(
    name_prefix = "live_ic_vs_jcodemunch",
    manifest = _MANIFEST,
    manifest_dir = _MANIFEST_DIR,
    artifact_root = _ARTIFACT_ROOT,
    bundle_path = _BUNDLE_PATH,
    dataset_config = _DATASET_CONFIG,
    dataset_split = _DATASET_SPLIT,
    dataset_max_items = _DATASET_MAX_ITEMS,
    dataset_skip = _DATASET_SKIP,
    evaluate_attempts = _EVALUATE_ATTEMPTS,
    stability_probe_attempts = _STABILITY_ATTEMPTS,
)
