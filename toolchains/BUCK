load("@nix//:flake.bzl", "flake")
load("@prelude//tests:test_toolchain.bzl", "noop_test_toolchain")
load("@prelude//toolchains:cxx.bzl", "system_cxx_toolchain")
load("@prelude//toolchains:genrule.bzl", "system_genrule_toolchain")
load("@prelude//toolchains:python.bzl", "remote_python_toolchain", "system_python_wheel_toolchain")
load("@prelude//toolchains:remote_test_execution.bzl", "remote_test_execution_toolchain")
load("@prelude//toolchains/go:system_go_bootstrap_toolchain.bzl", "system_go_bootstrap_toolchain")
load("@prelude//toolchains/go:system_go_toolchain.bzl", "system_go_toolchain")

_TARGET_MAPPING = [
    select({k: k for k in ["config//os:linux", "config//os:macos"]}),
    select({k: k for k in ["config//cpu:arm64", "config//cpu:x86_64"]}),
]

noop_test_toolchain(
    name = "test",
    visibility = ["PUBLIC"],
)

remote_test_execution_toolchain(
    name = "remote_test_execution",
    profiles = {},
    visibility = ["PUBLIC"],
)

system_genrule_toolchain(
    name = "genrule",
    visibility = ["PUBLIC"],
)

system_cxx_toolchain(
    name = "cxx",
    compiler_type = "clang",
    visibility = ["PUBLIC"],
)

# Prelude Go rules use PATH `go` from nix develop (copies GOROOT at build time).
system_go_bootstrap_toolchain(
    name = "go_bootstrap",
    visibility = ["PUBLIC"],
)

system_go_toolchain(
    name = "go",
    visibility = ["PUBLIC"],
)

# Hermetic CPython 3.13 (matches IC uv.lock cp313; IC checks use uv wrappers, not prelude python_*).
remote_python_toolchain(
    name = "python",
    visibility = ["PUBLIC"],
)

system_python_wheel_toolchain(
    name = "python_wheel",
    visibility = ["PUBLIC"],
)

# Nix-backed executables for custom rules (pkl, uv, npm, git) and developer workflows.
flake.package(
    name = "python_nix",
    binary = "python3",
    package = "python3",
    path = ".",
    target_compatible_with = _TARGET_MAPPING,
    visibility = ["PUBLIC"],
)

flake.package(
    name = "go_nix",
    binary = "go",
    package = "go",
    path = ".",
    target_compatible_with = _TARGET_MAPPING,
    visibility = ["PUBLIC"],
)

flake.package(
    name = "pkl",
    binary = "pkl",
    package = "pkl",
    path = ".",
    target_compatible_with = _TARGET_MAPPING,
    visibility = ["PUBLIC"],
)

flake.package(
    name = "ruff",
    binary = "ruff",
    package = "ruff",
    path = ".",
    target_compatible_with = _TARGET_MAPPING,
    visibility = ["PUBLIC"],
)

flake.package(
    name = "uv",
    binary = "uv",
    package = "uv",
    path = ".",
    target_compatible_with = _TARGET_MAPPING,
    visibility = ["PUBLIC"],
)

flake.package(
    name = "git",
    binary = "git",
    package = "git",
    path = ".",
    target_compatible_with = _TARGET_MAPPING,
    visibility = ["PUBLIC"],
)

flake.package(
    name = "npm",
    binary = "npm",
    package = "nodejs",
    path = ".",
    target_compatible_with = _TARGET_MAPPING,
    binaries = ["node", "npm"],
    visibility = ["PUBLIC"],
)
