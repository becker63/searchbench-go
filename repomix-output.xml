    ],
)

# Full gate: Go `check` + Iterative Context `check_full` (adds basedpyright) + Repomix snapshot freshness (pre-push / manual).
test_suite(
    name = "check_full",
    tests = [
        "//src/searchbench-go:check",
        "//src/iterative-context:check_full",
        ":repomix_fresh_check",
    ],
)
</file>

