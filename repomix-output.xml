<file path="configs/schema/SearchBenchExperiment.pkl">
@go.Package { name = "github.com/becker63/searchbench-go/internal/adapters/config/pkl/generated" }
module searchbench.config.Experiment

import "package://pkg.pkl-lang.org/pkl-go/pkl.golang@0.13.2#/go.pkl"

name: String

mode: RunMode = "evaluation"

dataset: Dataset

interfaces: Interfaces = new {}
systems: Systems
artifacts: Artifacts = new {}
agents: Agents = new {}
evaluation: Evaluation?
optimization: Optimization?

typealias RunMode =
  "evaluation" |
  "optimization"

typealias DatasetKind = "lca"
typealias Backend = "iterative_context" | "jcodemunch" | "fake"
typealias Provider = "openai" | "openrouter" | "cerebras" | "fake"
typealias ReportFormat = "json" | "text"
typealias TracingProvider = "langsmith"
typealias ArtifactKind =
  "policy" |
  "policy_proposal" |
  "completed_evaluation_bundle"
typealias OptimizerEvidenceKind =
  "report_summary" |
  "score_evidence" |
  "objective_result" |
  "candidate_policy"
typealias OptimizerDeniedEvidenceKind =
  "gold_labels" |
  "oracle_files" |
  "raw_dataset_answers"

class Dataset {
  kind: DatasetKind = "lca"
  name: String = "JetBrains-Research/lca-bug-localization"
  config: String
  split: String
  maxItems: Int(this > 0)?
}

class Interfaces {
  iterativeContextSelectionPolicyV1: Interface = new {
    id = "iterative_context.selection_policy.v1"
  }
}

class Interface {
  id: String
}

class Systems {
  baseline: System
  iterativeContext: System
}

class System {
  id: String
  name: String = id
  backend: Backend
  promptBundle: PromptBundle = new {}
  runtime: Runtime = new {}
}

class PromptBundle {
  name: String = "default"
  version: String? = "dev"
}

class Runtime {
  maxSteps: Int(this > 0) = 16
  timeoutSeconds: Int(this > 0) = 300
}

class Artifacts {
  candidatePolicyRound001: PolicyArtifact?
  candidatePolicyRound002: PolicyProposalArtifact?
  parentEvaluationRound001: CompletedEvaluationBundleArtifact?
}

class PolicyArtifact {
  id: String
  kind: "policy" = "policy"
  path: String
  implements: Interface
}

class PolicyProposalArtifact {
  id: String
  kind: "policy_proposal" = "policy_proposal"
  artifactName: String
  implements: Interface
}

class CompletedEvaluationBundleArtifact {
  id: String
  kind: "completed_evaluation_bundle" = "completed_evaluation_bundle"
  path: String
}

class Agents {
  evaluator: Evaluator?
  optimizer: Optimizer?
}

class AgentToolPolicy {
  allow: Listing<String> = new {}
  deny: Listing<String> = new {}
}

class Model {
  provider: Provider
  name: String
  routing: String?
  maxOutputTokens: Int(this > 0)? = 2000
}

class AgentBounds {
  maxModelTurns: Int(this > 0) = 8
  maxToolCalls: Int(this >= 0) = 24
  timeoutSeconds: Int(this > 0) = 300
}

class Evaluator {
  model: Model
  bounds: AgentBounds = new {}
  tools: AgentToolPolicy = new {}
  systemPrompt: String?
  retry: RetryPolicy = new {}
  tracing: Tracing?
}

class Optimizer {
  model: Model
  bounds: AgentBounds = new {}
  tools: AgentToolPolicy = new {}
  systemPrompt: String?
}

class RetryPolicy {
  maxAttempts: Int(this > 0) = 2
  retryOnModelError: Boolean = true
  retryOnToolFailure: Boolean = false
  retryOnFinalizationFailure: Boolean = true
  retryOnInvalidPrediction: Boolean = true
}

class Tracing {
  enabled: Boolean = false
  provider: TracingProvider?
  project: String?
}

class Evaluation {
  agent: Evaluator
  baseline: EvaluationSystemBinding
  candidate: CandidateEvaluationBinding
  scoring: Scoring
  report: Report = new {}
}

class EvaluationSystemBinding {
  system: System
}

class CandidateEvaluationBinding {
  system: System
  uses: CandidateUses = new {}
}

class CandidateUses {
  selectionPolicy: PolicyArtifact
}

class Scoring {
  objective: String
}

class Report {
  formats: Listing<ReportFormat> = new {
    "json"
    "text"
  }
}

class Optimization {
  agent: Optimizer
  parentRun: ParentRun
  target: OptimizationTarget
  evidence: OptimizationEvidence = new {}
}

class ParentRun {
  bundle: CompletedEvaluationBundleArtifact
}

class OptimizationTarget {
  input: PolicyArtifact
  output: PolicyProposalArtifact
}

class OptimizationEvidence {
  from: CompletedEvaluationBundleArtifact

  include: Listing<OptimizerEvidenceKind> = new {
    "report_summary"
    "score_evidence"
    "objective_result"
    "candidate_policy"
  }

  deny: Listing<OptimizerDeniedEvidenceKind> = new {
    "gold_labels"
    "oracle_files"
    "raw_dataset_answers"
  }
}
