		},
	)

	recorder := &evaluatorcallbacks.FakeTestRecorder{}
	evaluator, err := New(Config{
		Model:   model,
		WorkDir: "/repo",
		Tools: []tool.BaseTool{fakeTool{
			name:   "fake_resolve",
			result: `{"resolved_path":"src/main.go"}`,
