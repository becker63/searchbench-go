  }

  evidence {
    from = artifacts.parentEvaluationRound001

    include {
      "report_summary"
      "score_evidence"
      "objective_result"
      "candidate_policy"
    }

    deny {
      "gold_labels"
      "oracle_files"
      "raw_dataset_answers"
    }
  }
}
