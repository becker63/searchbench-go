func fixedClock() func() time.Time {
	fixed := time.Date(2026, 4, 25, 12, 0, 0, 0, time.UTC)
	return func() time.Time { return fixed }
}

func equalPhases(got []Phase, want []Phase) bool {
	if len(got) != len(want) {
		return false
	}
	for i := range got {
		if got[i] != want[i] {
			return false
		}
	}
	return true
}

