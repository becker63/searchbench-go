// round skips the optimizer and produces an evaluation-only bundle.
type Input struct {
	EvaluationManifestPath   string
	OptimizationManifestPath string
	BundleRootOverride       string
	RoundID                  string
	OptimizerBundleID        string
	DisableRenderReport      bool
