<file path="configs/rounds/local-ic-vs-jcodemunch/scoring/localization-objective.pkl">
amends "../../../schema/SearchBenchObjective.pkl"
import "../../../schema/SearchBenchObjectiveHelpers.pkl" as helpers

local maxHop = 12.0
local tokenBudget = 20000.0

objectiveId = "localization-v1"

local challengerQuality =
  1.0 - (if (current.localizationDistance.goldHop.challenger < maxHop) current.localizationDistance.goldHop.challenger else maxHop) / maxHop

local parentChallengerQuality =
  if (parent != null)
    1.0 - (if (parent.localizationDistance.goldHop.challenger < maxHop) parent.localizationDistance.goldHop.challenger else maxHop) / maxHop
  else
    challengerQuality

local improvementVsParent = challengerQuality - parentChallengerQuality

local tokenEfficiency =
  1.0 - (if (current.challengerUsage.totalTokens < tokenBudget) current.challengerUsage.totalTokens else tokenBudget) / tokenBudget

local base = (challengerQuality * 0.8) + (tokenEfficiency * 0.2)

local regressionPenalty =
  if (current.regressions.severeCount > 0) 0.0 else 1.0

local invalidPredictionPenalty =
  if (current.invalidPredictions.known && current.invalidPredictions.count > 0) 0.0 else 1.0

local finalScore = base * regressionPenalty * invalidPredictionPenalty

values = new {
  helpers.intermediate("challengerQuality", challengerQuality)
  helpers.intermediate("parentChallengerQuality", parentChallengerQuality)
  helpers.intermediate("improvementVsParent", improvementVsParent)
  helpers.intermediate("tokenEfficiency", tokenEfficiency)
  helpers.intermediate("base", base)
  helpers.penalty("regressionPenalty", regressionPenalty)
  helpers.penalty("invalidPredictionPenalty", invalidPredictionPenalty)
  helpers.finalValue("final", finalScore)
}

final = "final"

bounds = new ObjectiveBounds {
  min = 0.0
  max = 1.0
}
</file>

<file path="configs/rounds/local-ic-vs-jcodemunch/round.pkl">
amends "../../schema/SearchBenchRound.pkl"

name = "local-ic-vs-jcodemunch-round-001"
mode = "evaluation"

interfaces {
  iterativeContextSelectionPolicyV1 {
    id = "iterative_context.selection_policy.v1"
  }
}

dataset {
  kind = "lca"
  name = "JetBrains-Research/lca-bug-localization"
  config = "py"
  split = "dev"
  maxItems = 5
}

policies {
  incumbent {
    id = "jcodemunch"
    name = "jCodeMunch"
    backend = "jcodemunch"
  }

  challenger {
    id = "iterative-context"
    name = "Iterative Context"
    backend = "iterative_context"
  }
}

artifacts {
  challengerPolicy {
    id = "challenger-policy-round-001"
    kind = "policy"
    path = "policies/challenger_policy.py"
    implements = interfaces.iterativeContextSelectionPolicyV1
  }
}

agents {
  evaluator {
    model {
      provider = "fake"
      name = "fake-evaluator"
      maxOutputTokens = 2000
    }

    bounds {
      maxModelTurns = 8
      maxToolCalls = 24
      timeoutSeconds = 300
    }

    tools {
      allow {
        "resolve"
        "expand"
        "resolve_and_expand"
      }

      deny {
        "shell"
        "go_test"
        "write_file"
        "network"
      }
    }

    systemPrompt = """
    Use structural code evidence before guessing.
    Prefer the smallest plausible file set.
    Do not invent files that were not returned by tools.
    """
  }
}

evaluation {
  agent = agents.evaluator

  incumbent {
    system = policies.incumbent
  }

  challenger {
    system = policies.challenger

    uses {
      selectionPolicy = artifacts.challengerPolicy
    }
  }

  scoring {
    objective = "scoring/localization-objective.pkl"
  }
}
