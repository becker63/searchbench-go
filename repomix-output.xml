		</repo>
		<issue>
			<title>{ in.IssueTitle }</title>
			<body>{ in.IssueBody }</body>
		</issue>
		<available-tools>
			for _, toolName := range in.AllowedTools {
				<tool>{ toolName }</tool>
			}
		</available-tools>
		<constraints>
			for _, constraint := range in.Constraints {
				<constraint>{ constraint }</constraint>
			}
		</constraints>
		if len(in.RetryFeedback) > 0 {
			<retry-feedback>
				for _, feedback := range in.RetryFeedback {
					<attempt-feedback>{ feedback }</attempt-feedback>
				}
			</retry-feedback>
		}
		<output-contract>
