	if got := string(mustReadFile(t, manifestPath)); got != string(manifestBefore) {
		t.Fatal("manifest was mutated")
	}
	if got := string(mustReadFile(t, inputPolicyPath)); got != string(policyBefore) {
		t.Fatal("input policy was mutated")
	}
