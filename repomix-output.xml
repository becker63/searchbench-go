package logging

import "github.com/charmbracelet/lipgloss"

// Styles controls pretty development log rendering.
type Styles struct {
	Time                lipgloss.Style
	Info                lipgloss.Style
	Warn                lipgloss.Style
	Error               lipgloss.Style
	Event               lipgloss.Style
	ComparisonStarted   lipgloss.Style
	ComparisonCompleted lipgloss.Style
