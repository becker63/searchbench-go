	for i := 1; i <= taskCount; i++ {
		tasks = append(tasks, demoTask(i))
	}

	return compare.NewPlan(
		domain.NewPair(
			demoBaselineSystem(),
			demoCandidateSystem(demoPolicySource),
		),
		domain.NewNonEmpty(tasks[0], tasks[1:]...),
