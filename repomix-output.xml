			name: "valid",
			items: map[domain.TaskID]string{
				task1: "a",
				task2: "b",
			},
			order: []domain.TaskID{task2, task1},
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			t.Parallel()

			set, err := NewTaskRunSet(tt.items, tt.order)
