	if err := doc.Validate(); err == nil || !strings.Contains(err.Error(), ErrMissingEvidenceSchemaVersion.Error()) {
		t.Fatalf("Validate() error = %v, want missing schema version error", err)
	}

	doc.SchemaVersion = EvidenceSchemaVersion
