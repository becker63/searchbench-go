			},
		},
		PromotionDecision{
			Decision: DecisionReview,
			Reason:   "candidate improves core metrics but has a minor cost regression",
		},
	)
	out.CreatedAt = time.Date(2026, 4, 26, 15, 4, 5, 0, time.UTC)
	return out
}

