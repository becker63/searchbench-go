			args: []string{"--quiet", "demo-report", "--max-workers", "0"},
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			t.Parallel()

			err := RunWithWriters(context.Background(), tt.args, &bytes.Buffer{}, io.Discard)
