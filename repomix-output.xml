		{
			name: "wrong interface",
			raw:  `{"artifact_id":"next-challenger-round-002","artifact_name":"next_next_challenger_policy.round-002.py","interface_id":"wrong","code":"def score_fn(node, graph, depth):\n    return 0.0\n"}`,
