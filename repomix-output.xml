var _ encoding.BinaryUnmarshaler = new(ArtifactKind)

// UnmarshalBinary implements encoding.BinaryUnmarshaler for ArtifactKind.
func (rcv *ArtifactKind) UnmarshalBinary(data []byte) error {
	switch str := string(data); str {
