				Config: "py",
				Split:  "dev",
			},
			Systems: domain.NewPair(baseline.Ref(), candidate.Ref()),
			Tasks:   tasks,
			Parallelism: ParallelismConfig{
				Mode:       "sequential",
				MaxWorkers: 1,
			},
			Evaluator: EvaluatorConfig{
				Model: EvaluatorModelConfig{
					Provider:        "openai",
					Name:            "gpt-candidate",
					MaxOutputTokens: 2048,
